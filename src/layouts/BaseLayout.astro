---
import UnifiedNav from "../components/UnifiedNav.astro";
import { isCurrentItem, isCurrentLink, siteChrome, withBasePath } from "../lib/siteChrome";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Open source learning pathways and curated lessons from the UC OSPO Network.",
} = Astro.props as Props;

const basePath = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const sidebarItems = siteChrome.nav.map((item) => ({
  ...item,
  current: isCurrentItem(basePath, Astro.url.pathname, item),
  hrefResolved: item.external ? item.href : withBasePath(import.meta.env.BASE_URL, item.href),
  childrenResolved: item.children?.map((child) => ({
    ...child,
    current: isCurrentLink(basePath, Astro.url.pathname, child.href),
    hrefResolved: child.external ? child.href : withBasePath(import.meta.env.BASE_URL, child.href),
  })),
}));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles.css`} />
    <title>{title} | UC OSPO Education</title>
  </head>
  <body>
    <div class="site-shell">
      <UnifiedNav />

      <script>
        if (import.meta.env.DEV) {
          import("react").then(async (React) => {
            import("react-dom").then(async (ReactDOM) => {
              const axe = (await import("@axe-core/react")).default;
              axe(React, ReactDOM, 1000);
            });
          });
        }
      </script>

      <main id="main-content" class="site-main">
        <div class="site-layout">
          <aside class="site-sidebar" aria-label="Section navigation">
            <div class="site-sidebar__inner">
              <p class="site-sidebar__eyebrow">UC OSPO Network</p>
              <nav class="site-sidebar__nav" aria-label="Site sections">
                <ul class="site-sidebar__list">
                  {sidebarItems.map((item) => (
                    <li class={`site-sidebar__item${item.current ? " is-current" : ""}`}>
                      <a
                        class="site-sidebar__link"
                        href={item.hrefResolved}
                        target={item.external ? "_blank" : undefined}
                        rel={item.external ? "noopener noreferrer" : undefined}
                      >
                        {item.label}
                      </a>

                      {item.childrenResolved?.length ? (
                        <ul class="site-sidebar__sublist">
                          {item.childrenResolved.map((child) => (
                            <li class={`site-sidebar__subitem${child.current ? " is-current" : ""}`}>
                              <a
                                class="site-sidebar__sublink"
                                href={child.hrefResolved}
                                target={child.external ? "_blank" : undefined}
                                rel={child.external ? "noopener noreferrer" : undefined}
                              >
                                {child.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      ) : null}
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>

          <div class="site-content">
            <slot />
          </div>
        </div>
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <a class="site-footer__brand" href={siteChrome.brand.homeHref} aria-label="UC OSPO Network">
            <img
              src={`${import.meta.env.BASE_URL}uc-ospo-network-logo.svg`}
              alt="UC OSPO Network"
              class="logo-dark"
            />
            <img
              src={`${import.meta.env.BASE_URL}uc-ospo-network-logo-light.svg`}
              alt="UC OSPO Network"
              class="logo-light"
            />
          </a>

          <nav class="site-footer__social" aria-label="UC OSPO social links">
            {siteChrome.footer.social.map((item) => (
              <a
                class="site-footer__social-link"
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noopener noreferrer" : undefined}
                aria-label={item.label}
              >
                <img src={`${import.meta.env.BASE_URL}${item.icon.replace(/^\//, "")}`} alt="" aria-hidden="true" />
              </a>
            ))}
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PathwayCard from "../../components/PathwayCard.astro";
import { getCollection } from "astro:content";
import { getLessons } from "../../lib/lessons";

const [pathways, allLessons] = await Promise.all([
  getCollection("pathways"),
  getLessons(),
]);

pathways.sort((a, b) => a.data.order - b.data.order);

const activeLessons = allLessons.filter(
  (l) => (l.keepStatus === "keep" || l.keepStatus === "keepCandidate") && l.url.trim() !== "",
);

const lessonCountByPathway: Record<string, number> = {};
for (const lesson of activeLessons) {
  for (const pid of lesson.pathways) {
    lessonCountByPathway[pid] = (lessonCountByPathway[pid] ?? 0) + 1;
  }
}
---

<style>
  .pathways-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
    padding-bottom: 2rem;
  }
</style>

<BaseLayout
  title="Learning Pathways"
  description="Explore the UC OSPO learning pathways organized by role, interests, and experience level."
>
  <section class="page-intro">
    <div class="content-container">
      <p class="page-intro__eyebrow">Education</p>
      <h1 class="page-intro__title">Learning Pathways</h1>
      <p class="page-intro__summary">
        Explore structured routes through the curriculum based on role, interests, and open source
        experience.
      </p>
    </div>
  </section>

  <div class="content-container">
    <div class="pathways-grid">
      {pathways.map((pathway) => (
        <PathwayCard
          pathway={{ id: pathway.id, ...pathway.data }}
          lessonCount={lessonCountByPathway[pathway.id] ?? 0}
        />
      ))}
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PathwayCard from "../../components/PathwayCard.astro";
import { PATHWAYS } from "../../types/lesson.ts";
---

<style>
  .pathways-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
    padding-bottom: 2rem;
  }
</style>

<BaseLayout
  title="Learning Pathways"
  description="Explore the UC OSPO learning pathways organized by role, interests, and experience level."
>
  <section class="page-intro">
    <div class="content-container">
      <p class="page-intro__eyebrow">Education</p>
      <h1 class="page-intro__title">Learning Pathways</h1>
      <p class="page-intro__summary">
        Explore structured routes through the curriculum based on role, interests, and open source
        experience.
      </p>
    </div>
  </section>

  <div class="content-container">
    <div class="pathways-grid">
      {PATHWAYS.map((pathway) => (
        <PathwayCard pathway={pathway} />
      ))}
    </div>
  </div>
</BaseLayout>

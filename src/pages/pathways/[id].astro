---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLessons } from "../../lib/lessons";
import { PATHWAYS, type PathwayInfo, type Lesson } from "../../types/lesson";
import LessonCard from "../../components/LessonCard.jsx";
import "../../components/lessons/lessons.css";

interface Props {
  pathway: PathwayInfo;
  lessons: Lesson[];
}

export async function getStaticPaths() {
  const lessons = await getLessons();
  return PATHWAYS.map((pathway) => ({
    params: { id: pathway.id },
    props: { pathway, lessons },
  }));
}

const { pathway, lessons } = Astro.props as Props;

const pathwayLessons = lessons.filter(
  (lesson) =>
    (lesson.keepStatus === "keep" || lesson.keepStatus === "keepCandidate") &&
    lesson.url.trim() !== "" &&
    pathway.learnerCategories.includes(lesson.learnerCategory),
);

const lessonIndex = Object.fromEntries(
  lessons
    .filter((lesson) => lesson.slug && lesson.url)
    .map((lesson) => [
      lesson.slug,
      {
        name: lesson.name || lesson.slug,
        url: lesson.url,
      },
    ]),
);

const groupedLessons = pathwayLessons.reduce<Record<string, Lesson[]>>((acc, lesson) => {
  const topic = lesson.subTopic || "Other";
  if (!acc[topic]) acc[topic] = [];
  acc[topic].push(lesson);
  return acc;
}, {});
---

<style>
  .pathway-content {
    padding-bottom: 2rem;
  }

  .pathway-section + .pathway-section {
    margin-top: 2rem;
  }

  .pathway-subtopic {
    margin: 0 0 1rem;
    color: var(--text-primary);
    font-size: 1.3rem;
  }

  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18.5rem, 1fr));
    gap: 1.5rem;
  }

  .pathway-empty p {
    margin: 0;
  }
</style>

<BaseLayout title={pathway.name} description={pathway.description}>
  <section class="page-intro">
    <div class="content-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href={import.meta.env.BASE_URL}>Home</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li><a href={`${import.meta.env.BASE_URL}pathways`}>Pathways</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li aria-current="page">{pathway.name}</li>
        </ol>
      </nav>
      <p class="page-intro__eyebrow">Pathway</p>
      <h1 class="page-intro__title">{pathway.name}</h1>
      <p class="page-intro__summary">{pathway.description}</p>
      <div class="page-intro__actions">
        <a class="button-secondary" href={`${import.meta.env.BASE_URL}pathways`}>Back to All Pathways</a>
        <a class="button-link" href={`${import.meta.env.BASE_URL}lessons`}>Browse all lessons</a>
      </div>
    </div>
  </section>

  <div class="content-container pathway-content">
    {Object.keys(groupedLessons).length === 0 ? (
      <section class="page-section empty-state pathway-empty">
        <p>No lessons are available for this pathway yet.</p>
      </section>
    ) : (
      Object.entries(groupedLessons).map(([subtopic, subtopicLessons]) => (
        <section class="pathway-section page-section">
          <h2 class="pathway-subtopic">{subtopic}</h2>
          <div class="lesson-grid">
            {subtopicLessons.map((lesson) => (
              <LessonCard
                lesson={lesson}
                pathwayIcon={pathway.icon}
                lessonIndex={lessonIndex}
                headingLevel={3}
                client:load
              />
            ))}
          </div>
        </section>
      ))
    )}
  </div>
</BaseLayout>

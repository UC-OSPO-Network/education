---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLessons, type Lesson } from "../../lib/lessons";
import { getCollection } from "astro:content";
import LessonCard from "../../components/LessonCard.jsx";
import githubHealthRaw from "../../data/github-health.json";
import type { HealthSnapshot } from "../../lib/githubHealth";
import "../../components/lessons/lessons.css";

const healthData = githubHealthRaw as unknown as HealthSnapshot;

interface Props {
  id: string;
  name: string;
  description: string;
  icon: string;
  lessons: Lesson[];
}

export async function getStaticPaths() {
  const [lessons, pathways] = await Promise.all([
    getLessons(),
    getCollection("pathways"),
  ]);

  return pathways.map((pathway) => ({
    params: { id: pathway.id },
    props: {
      id: pathway.id,
      name: pathway.data.name,
      description: pathway.data.description,
      icon: pathway.data.icon,
      lessons,
    } satisfies Props,
  }));
}

const { id, name, description, lessons } = Astro.props as Props;

const pathwayLessons = lessons.filter(
  (lesson) =>
    (lesson.keepStatus === "keep" || lesson.keepStatus === "keepCandidate") &&
    lesson.url.trim() !== "" &&
    lesson.pathways.includes(id),
);

const lessonIndex = Object.fromEntries(
  lessons
    .filter((lesson) => lesson.slug && lesson.url)
    .map((lesson) => [lesson.slug, { name: lesson.name || lesson.slug, url: lesson.url }]),
);

const groupedLessons = pathwayLessons.reduce<Record<string, Lesson[]>>((acc, lesson) => {
  const topic = lesson.subTopic || "Other";
  if (!acc[topic]) acc[topic] = [];
  acc[topic].push(lesson);
  return acc;
}, {});

const LEVEL_ORDER: Record<string, number> = { beginner: 0, intermediate: 1, advanced: 2 };

for (const group of Object.values(groupedLessons)) {
  group.sort((a, b) => {
    const levelDiff =
      (LEVEL_ORDER[a.educationalLevel.toLowerCase()] ?? 3) -
      (LEVEL_ORDER[b.educationalLevel.toLowerCase()] ?? 3);
    if (levelDiff !== 0) return levelDiff;
    return (parseInt(a.sortingId) || 999) - (parseInt(b.sortingId) || 999);
  });
}

const sortedGroups = Object.entries(groupedLessons).sort(([keyA, aLessons], [keyB, bLessons]) => {
  if (keyA === "Other") return 1;
  if (keyB === "Other") return -1;
  const minA = Math.min(...aLessons.map((l) => parseInt(l.sortingId) || 999));
  const minB = Math.min(...bLessons.map((l) => parseInt(l.sortingId) || 999));
  return minA - minB;
});
---

<style>
  .pathway-content {
    padding-bottom: 2rem;
  }

  .pathway-section + .pathway-section {
    margin-top: 2rem;
  }

  .pathway-subtopic {
    margin: 0 0 1rem;
    color: var(--text-primary);
    font-size: 1.3rem;
  }

  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18.5rem, 1fr));
    gap: 1.5rem;
  }

  .pathway-empty p {
    margin: 0;
  }
</style>

<BaseLayout title={name} description={description}>
  <section class="page-intro">
    <div class="content-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href={import.meta.env.BASE_URL}>Home</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li><a href={`${import.meta.env.BASE_URL}pathways`}>Pathways</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li aria-current="page">{name}</li>
        </ol>
      </nav>
      <p class="page-intro__eyebrow">Pathway</p>
      <h1 class="page-intro__title">{name}</h1>
      <p class="page-intro__summary">{description}</p>
      <div class="page-intro__actions">
        <a class="button-secondary" href={`${import.meta.env.BASE_URL}pathways`}>Back to All Pathways</a>
        <a class="button-link" href={`${import.meta.env.BASE_URL}lessons`}>Browse all lessons</a>
      </div>
    </div>
  </section>

  <div class="content-container pathway-content">
    {Object.keys(groupedLessons).length === 0 ? (
      <section class="page-section empty-state pathway-empty">
        <p>No lessons are available for this pathway yet.</p>
      </section>
    ) : (
      sortedGroups.map(([subtopic, subtopicLessons]) => (
        <section class="pathway-section page-section">
          <h2 class="pathway-subtopic">{subtopic}</h2>
          <div class="lesson-grid">
            {subtopicLessons.map((lesson) => (
              <LessonCard
                lesson={lesson}
                lessonIndex={lessonIndex}
                health={healthData.lessons[lesson.slug] ?? null}
                headingLevel={3}
                client:load
              />
            ))}
          </div>
        </section>
      ))
    )}
  </div>
</BaseLayout>

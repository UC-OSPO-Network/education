---
import BaseLayout from "../layouts/BaseLayout.astro";
import LessonFilter from "../components/LessonFilter.tsx";
import { getActiveLessons } from "../lib/lessons";
import "../components/lessons/lessons.css";

const activeLessons = await getActiveLessons();
---

<BaseLayout
  title="All Lessons"
  description="Browse the full library of curated open source education lessons from the UC OSPO Network."
>
  <section class="page-intro">
    <div class="content-container">
      <p class="page-intro__eyebrow">Education</p>
      <h1 class="page-intro__title">All Lessons</h1>
      <p class="page-intro__summary">
        Browse the full library of curated open source learning materials, then filter by role,
        pathway, skill level, or topic.
      </p>
    </div>
  </section>

  {activeLessons.length === 0 ? (
    <div class="content-container">
      <div class="page-section empty-state">
        <h2>No lessons found</h2>
        <p>No lessons are currently available.</p>
      </div>
    </div>
  ) : (
    <LessonFilter lessons={activeLessons} client:load />
  )}
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import WelcomeHeader from '../components/home/WelcomeHeader.astro';
import BrowseAllLessonsPanel from '../components/home/BrowseAllLessonsPanel.astro';
import PathwayShowcase from '../components/home/PathwayShowcase';
import '../components/home/home.css';
import { getCollection } from 'astro:content';
import { getActiveLessons, type Lesson } from '../lib/lessons';
import type { CategoryIconName, HomepagePathwayItem, HomepagePathwaySection } from '../components/home/types';

const [activeLessons, pathways] = await Promise.all([
  getActiveLessons(),
  getCollection('pathways'),
]);

const sortedPathways = pathways.sort((a, b) => a.data.order - b.data.order);

function getSectionSortKey(lessons: Lesson[]) {
  return lessons
    .map((lesson) => lesson.sortingId?.trim())
    .filter(Boolean)
    .sort((a, b) => a!.localeCompare(b!, undefined, { numeric: true }))[0] ?? null;
}

function buildHomepageSections(pathwayId: string): HomepagePathwaySection[] {
  const grouped = activeLessons
    .filter((lesson) => lesson.pathways.includes(pathwayId))
    .reduce<Record<string, Lesson[]>>((acc, lesson) => {
      const title = lesson.subTopic?.trim() || 'Other';
      acc[title] ??= [];
      acc[title].push(lesson);
      return acc;
    }, {});

  return Object.entries(grouped)
    .sort(([titleA, lessonsA], [titleB, lessonsB]) => {
      const keyA = getSectionSortKey(lessonsA);
      const keyB = getSectionSortKey(lessonsB);
      if (keyA && keyB) return keyA.localeCompare(keyB, undefined, { numeric: true });
      if (keyA) return -1;
      if (keyB) return 1;
      return titleA.localeCompare(titleB);
    })
    .map(([title, lessons]) => ({ title, lessons: lessons.slice(0, 4) }))
    .slice(0, 2);
}

const homepagePathways: HomepagePathwayItem[] = sortedPathways.map((pathway) => ({
  id: pathway.id,
  title: pathway.data.name,
  description: pathway.data.description,
  iconName: pathway.id as CategoryIconName,
  sections: buildHomepageSections(pathway.id),
}));

const defaultHomepagePathwayId =
  homepagePathways.find((pathway) => pathway.sections.length > 0)?.id ??
  homepagePathways[0]?.id ??
  '';
---

<BaseLayout title="Open Source Learning Pathways">
  <div class="home-page">
    <WelcomeHeader />

    <section class="home-showcase" aria-labelledby="pathways-heading">
      <h2 id="pathways-heading" class="sr-only">Learning pathways</h2>
      <PathwayShowcase items={homepagePathways} defaultActiveId={defaultHomepagePathwayId} client:load />
      <BrowseAllLessonsPanel />
    </section>
  </div>
</BaseLayout>

---
const homeHref = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${homeHref}`} />
    <link rel="canonical" href={homeHref} />
    <title>Redirecting | UC OSPO Education</title>
  </head>
  <body data-pagefind-ignore>
    <p>Search is now available from the site header. Redirecting to <a href={homeHref}>UC OSPO Education</a>.</p>
    <script define:vars={{ homeHref }}>
      window.location.replace(homeHref);
    </script>
  </body>
</html>

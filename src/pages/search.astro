---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const pagefindPath = `${base}pagefind/`;
const pagefindCss = `${pagefindPath}pagefind-component-ui.css`;
---

<BaseLayout
  title="Search"
  description="Search all lessons and resources in the UC OSPO Education catalog."
>
  <Fragment slot="head">
    <link rel="stylesheet" href={pagefindCss} />
  </Fragment>

  <section class="page-intro">
    <div class="content-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href={base}>Home</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li aria-current="page">Search</li>
        </ol>
      </nav>
      <h1 class="page-intro__title">Search</h1>
      <p class="page-intro__summary">
        Find lessons, pathways, and resources across the UC OSPO Education catalog.
      </p>
    </div>
  </section>

  <div class="content-container">
    <div class="search-page page-section" data-pagefind-ignore="all">
      <div id="search">
        <noscript>JavaScript is required for site search.</noscript>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .search-page {
    padding-block: 1.5rem;
    max-width: 52rem;
  }

  #search pagefind-searchbox {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--uc-blue);
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--bg-primary);
    --pagefind-ui-border: var(--border-light);
    --pagefind-ui-tag: var(--bg-surface-strong);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-font: var(--font-sans);
  }

  .search-unavailable {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .search-unavailable code {
    font-family: var(--font-mono);
    background: var(--bg-surface-strong);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
  }
</style>

<script define:vars={{ pagefindPath, base }}>
  (async () => {
    const el = document.getElementById("search");
    if (!el) return;
    try {
      // Load pagefind core and set base URL before the UI initialises.
      // baseUrl tells pagefind to prefix all result URLs with /education/
      // so links resolve correctly on the GitHub Pages subpath deployment.
      const pf = await import(pagefindPath + "pagefind.js");
      if (pf.options) await pf.options({ baseUrl: base });

      // Load the Component UI — registers <pagefind-searchbox> web component
      await import(pagefindPath + "pagefind-component-ui.js");

      // Swap in the web component (autofocus so users can type immediately)
      el.innerHTML = "<pagefind-searchbox autofocus></pagefind-searchbox>";
    } catch {
      el.innerHTML =
        '<p class="search-unavailable">Search index not found — run <code>npm run build</code> to generate it.</p>';
    }
  })();
</script>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLessons, type Lesson, formatDuration } from "../../lib/lessons";
import { PATHWAYS } from "../../types/lesson";

type Props = {
  lesson: Lesson;
  relatedLessons: Lesson[];
};

function formatValue(value: unknown): string {
  if (value === null || value === undefined) return "";
  if (Array.isArray(value)) return value.filter(Boolean).join(", ");
  if (typeof value === "string") return value.trim();
  if (typeof value === "number" || typeof value === "boolean") return String(value);
  try {
    return JSON.stringify(value);
  } catch {
    return String(value);
  }
}

function toTitleCaseLabel(key: string): string {
  return key
    .replace(/([a-z])([A-Z])/g, "$1 $2")
    .replace(/_/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

export async function getStaticPaths() {
  const lessons = await getLessons();

  const candidates = lessons.filter(
    (lesson) => typeof lesson.slug === "string" && lesson.slug.trim().length > 0,
  );

  return candidates.map((lesson) => {
    const relatedByPathway = lessons.filter(
      (other) =>
        other.slug !== lesson.slug &&
        other.keepStatus !== "drop" &&
        other.url.trim() !== "" &&
        other.learnerCategory === lesson.learnerCategory,
    );

    const relatedBySubtopic = relatedByPathway.filter((other) => {
      const currentSubtopic = lesson.subTopic?.trim() ?? "";
      const otherSubtopic = other.subTopic?.trim() ?? "";
      if (currentSubtopic === "") return otherSubtopic === "";
      return otherSubtopic === currentSubtopic;
    });

    const relatedLessons =
      relatedBySubtopic.length > 0 ? relatedBySubtopic : relatedByPathway;

    return {
      params: { slug: lesson.slug },
      props: {
        lesson,
        relatedLessons: relatedLessons.slice(0, 6),
      } satisfies Props,
    };
  });
}

const { lesson, relatedLessons } = Astro.props as Props;

const pathway = PATHWAYS.find((item) => item.learnerCategories.includes(lesson.learnerCategory));
const pathwayHref = pathway ? `${import.meta.env.BASE_URL}pathways/${pathway.id}` : "";
const summary =
  lesson.description?.trim() ||
  lesson.abstract?.trim() ||
  "No description is available for this lesson yet.";
const externalHref = lesson.url?.trim() ?? "";

const coreMetadata: Array<{ label: string; value: unknown; kind?: "link" }> = [
  { label: "Slug", value: lesson.slug },
  { label: "Pathway", value: lesson.learnerCategory, kind: pathwayHref ? "link" : undefined },
  { label: "Subtopic", value: lesson.subTopic },
  { label: "Skill Level", value: lesson.educationalLevel },
  { label: "OSS Role(s)", value: lesson.oss_role || lesson.ossRole || "" },
  { label: "Resource Type", value: lesson.learningResourceType },
  { label: "Time Required", value: formatDuration(lesson.timeRequired) },
  { label: "Author", value: lesson.author },
  { label: "License", value: lesson.license },
  { label: "Keywords", value: lesson.keywords },
  { label: "Language(s)", value: lesson.inLanguage },
];

const excludedAdditionalKeys = new Set<string>([
  "name",
  "slug",
  "keepStatus",
  "description",
  "abstract",
  "url",
  "author",
  "license",
  "learnerCategory",
  "educationalLevel",
  "ossRole",
  "oss_role",
  "subTopic",
  "timeRequired",
  "learningResourceType",
  "inLanguage",
  "keywords",
]);

const additionalMetadataEntries = Object.entries(lesson)
  .filter(([key, value]) => !excludedAdditionalKeys.has(key) && formatValue(value) !== "")
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([key, value]) => ({ label: toTitleCaseLabel(key), value }));
---

<BaseLayout title={lesson.name} description={summary}>
  <section class="page-intro">
    <div class="content-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href={import.meta.env.BASE_URL}>Home</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li><a href={`${import.meta.env.BASE_URL}lessons`}>Lessons</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li aria-current="page">{lesson.name}</li>
        </ol>
      </nav>
      <p class="page-intro__eyebrow">Lesson</p>
      <h1 class="page-intro__title">{lesson.name}</h1>
      <p class="page-intro__summary">{summary}</p>
      <div class="page-intro__actions">
        <a
          class="button-primary"
          href={externalHref || "#"}
          target={externalHref ? "_blank" : undefined}
          rel={externalHref ? "noopener noreferrer" : undefined}
          aria-disabled={externalHref ? "false" : "true"}
        >
          View External Lesson
        </a>
        {pathwayHref ? <a class="button-secondary" href={pathwayHref}>Browse This Pathway</a> : null}
      </div>
    </div>
  </section>

  <div class="content-container">
    <section class="page-section" aria-labelledby="lesson-metadata">
      <h2 class="section-heading" id="lesson-metadata">Lesson metadata</h2>
      <div class="metadata-grid">
        {coreMetadata.map(({ label, value, kind }) => {
          const formatted = formatValue(value);
          if (label === "Pathway" && kind === "link" && pathwayHref) {
            return (
              <div class="meta-item">
                <span class="meta-label">{label}</span>
                <span class="meta-value">
                  <a href={pathwayHref}>{formatted || "—"}</a>
                </span>
              </div>
            );
          }

          return (
            <div class="meta-item">
              <span class="meta-label">{label}</span>
              <span class="meta-value">{formatted || "—"}</span>
            </div>
          );
        })}
      </div>
    </section>

    {additionalMetadataEntries.length > 0 ? (
      <section class="page-section" aria-labelledby="additional-metadata">
        <h2 class="section-heading" id="additional-metadata">Additional metadata</h2>
        <div class="metadata-grid">
          {additionalMetadataEntries.map(({ label, value }) => (
            <div class="meta-item">
              <span class="meta-label">{label}</span>
              <span class="meta-value">{formatValue(value)}</span>
            </div>
          ))}
        </div>
      </section>
    ) : null}

    <section class="page-section" aria-labelledby="related-lessons">
      <h2 class="section-heading" id="related-lessons">Related lessons</h2>
      {relatedLessons.length === 0 ? (
        <p class="section-copy">No related lessons found yet.</p>
      ) : (
        <div class="related-grid">
          {relatedLessons.map((related) => (
            <a class="related-card" href={`${import.meta.env.BASE_URL}lessons/${related.slug}`}>
              <h3 class="related-title">{related.name}</h3>
              <p class="related-meta">
                {related.educationalLevel}
                {related.subTopic?.trim() ? ` • ${related.subTopic.trim()}` : ""}
              </p>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

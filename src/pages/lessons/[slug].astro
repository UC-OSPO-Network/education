---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LessonJsonLd from "../../components/LessonJsonLd.astro";
import { getLessons, type Lesson, formatDuration } from "../../lib/lessons";
import { PATHWAYS } from "../../types/lesson";
import githubHealthRaw from "../../data/github-health.json";
import type { HealthSnapshot } from "../../lib/githubHealth";
import { formatAuthorsApa, formatAuthorsBibtex } from "../../lib/githubHealth";

const healthData = githubHealthRaw as unknown as HealthSnapshot;

type Props = {
  lesson: Lesson;
  relatedLessons: Lesson[];
  prereqLessons: { slug: string; name: string }[];
};

export async function getStaticPaths() {
  const lessons = await getLessons();
  const slugToName = Object.fromEntries(lessons.map((l) => [l.slug, l.name]));

  const candidates = lessons.filter(
    (lesson) => typeof lesson.slug === "string" && lesson.slug.trim().length > 0,
  );

  return candidates.map((lesson) => {
    const relatedByPathway = lessons.filter(
      (other) =>
        other.slug !== lesson.slug &&
        other.keepStatus !== "drop" &&
        other.url.trim() !== "" &&
        other.learnerCategory === lesson.learnerCategory,
    );

    const relatedBySubtopic = relatedByPathway.filter((other) => {
      const currentSubtopic = lesson.subTopic?.trim() ?? "";
      const otherSubtopic = other.subTopic?.trim() ?? "";
      if (currentSubtopic === "") return otherSubtopic === "";
      return otherSubtopic === currentSubtopic;
    });

    const relatedLessons =
      relatedBySubtopic.length > 0 ? relatedBySubtopic : relatedByPathway;

    const prereqLessons = (lesson.dependsOn ?? [])
      .filter((slug) => slugToName[slug])
      .map((slug) => ({ slug, name: slugToName[slug] }));

    return {
      params: { slug: lesson.slug },
      props: {
        lesson,
        relatedLessons: relatedLessons.slice(0, 6),
        prereqLessons,
      } satisfies Props,
    };
  });
}

const { lesson, relatedLessons, prereqLessons } = Astro.props as Props;

const pathway = PATHWAYS.find((item) =>
  item.learnerCategories.includes(lesson.learnerCategory),
);
const pathwayHref = pathway
  ? `${import.meta.env.BASE_URL}pathways/${pathway.id}`
  : "";
const summary =
  lesson.description?.trim() ||
  lesson.abstract?.trim() ||
  "";
const externalHref = lesson.url?.trim() ?? "";

const repoHealth = lesson.repoUrl
  ? (healthData.lessons[lesson.repoUrl] ?? null)
  : null;
const repoLastUpdated = repoHealth?.pushedAt ?? null;

// Build citation — prefer CFF data, fall back to lesson metadata
const cffCitation = repoHealth?.citation ?? null;
const citationAuthors = cffCitation?.authors ?? [];
const citationYear = cffCitation?.dateReleased
  ? cffCitation.dateReleased.slice(0, 4)
  : new Date().getFullYear().toString();
const citationTitle = cffCitation?.title ?? lesson.name;
const citationDoi = cffCitation?.doi ?? null;
const citationUrl = citationDoi
  ? `https://doi.org/${citationDoi}`
  : lesson.url?.trim() || lesson.repoUrl?.trim() || "";
const citationVersion = cffCitation?.version ?? null;

const apaAuthors = formatAuthorsApa(citationAuthors, lesson.author);
const bibtexAuthors = formatAuthorsBibtex(citationAuthors, lesson.author);
const bibtexId = lesson.slug.replace(/-/g, '_');

const apaCitation = [
  `${apaAuthors} (${citationYear}).`,
  `${citationTitle}.`,
  citationVersion ? `(Version ${citationVersion}).` : null,
  `UC OSPO Network.`,
  citationUrl,
].filter(Boolean).join(' ');

const bibtexCitation = `@misc{${bibtexId}_${citationYear},
  author    = {${bibtexAuthors}},
  title     = {${citationTitle}},
  year      = {${citationYear}},
  publisher = {UC OSPO Network},
  url       = {${citationUrl}}${citationDoi ? `,\n  doi       = {${citationDoi}}` : ""}${citationVersion ? `,\n  version   = {${citationVersion}}` : ""}
}`;

// Parse bullet lines out of the learningObjectives block
const outcomeLines = (lesson.learningObjectives ?? "")
  .split("\n")
  .map((l) => l.trim())
  .filter((l) => l.startsWith("- ") || l.startsWith("* "))
  .map((l) => l.replace(/^[-*]\s+/, ""));

// Keywords as array
const keywordList = lesson.keywords
  ? lesson.keywords
      .split(",")
      .map((k) => k.trim())
      .filter(Boolean)
  : [];

// OSS roles as array
const ossRoles = (lesson.ossRole ?? lesson.oss_role ?? "")
  .split(",")
  .map((r) => r.trim())
  .filter(Boolean);

function shortLicense(url: string | undefined): string {
  if (!url) return "";
  const m = url.match(/licenses\/([^/]+)\/([^/]+)/);
  if (m) return `CC ${m[1].toUpperCase()} ${m[2]}`;
  const m2 = url.match(/licenses\/([^/]+)/);
  if (m2) return `CC ${m2[1].toUpperCase()}`;
  return url;
}

function formatMonth(dateStr: string | null): string {
  if (!dateStr) return "";
  const parts = dateStr.split("-");
  const year = parts[0];
  const month = parseInt(parts[1], 10);
  const names = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${names[month - 1]} ${year}`;
}

const duration = formatDuration(lesson.timeRequired);
const licenseShort = shortLicense(lesson.license);
const hasPrereqs = prereqLessons.length > 0 || !!lesson.competencyRequired?.trim();
---

<BaseLayout title={lesson.name} description={summary}>
  <Fragment slot="head">
    <LessonJsonLd lesson={lesson} canonicalUrl={Astro.url.href} />
  </Fragment>

  <section class="page-intro">
    <div class="content-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href={import.meta.env.BASE_URL}>Home</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li><a href={`${import.meta.env.BASE_URL}lessons`}>Lessons</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li aria-current="page">{lesson.name}</li>
        </ol>
      </nav>

      <div class="lesson-badges">
        {lesson.learnerCategory && (
          <span class="lesson-badge lesson-badge--pathway">
            {lesson.learnerCategory}
          </span>
        )}
        {lesson.educationalLevel && (
          <span class="lesson-badge lesson-badge--level">
            {lesson.educationalLevel}
          </span>
        )}
        {duration && (
          <span class="lesson-badge lesson-badge--time">{duration}</span>
        )}
      </div>

      <h1 class="page-intro__title">{lesson.name}</h1>
      {summary && <p class="page-intro__summary">{summary}</p>}

      <div class="page-intro__actions">
        <a
          class="button-primary"
          href={externalHref || "#"}
          target={externalHref ? "_blank" : undefined}
          rel={externalHref ? "noopener noreferrer" : undefined}
          aria-disabled={externalHref ? "false" : "true"}
        >
          View Lesson ↗
        </a>
        {pathwayHref && (
          <a class="button-secondary" href={pathwayHref}>Browse Pathway</a>
        )}
      </div>
    </div>
  </section>

  <div class="content-container">
    <div class="lesson-detail">

      <div class="lesson-body">
        {outcomeLines.length > 0 && (
          <section class="page-section" aria-labelledby="outcomes-heading">
            <h2 class="section-heading" id="outcomes-heading">Learning outcomes</h2>
            <ul class="lesson-outcomes">
              {outcomeLines.map((line) => <li>{line}</li>)}
            </ul>
          </section>
        )}

        {hasPrereqs && (
          <section class="page-section" aria-labelledby="prereqs-heading">
            <h2 class="section-heading" id="prereqs-heading">Prerequisites</h2>
            {prereqLessons.length > 0 && (
              <ul class="lesson-prereq-list">
                {prereqLessons.map(({ slug, name }) => (
                  <li>
                    <a href={`${import.meta.env.BASE_URL}lessons/${slug}`}>
                      {name}
                    </a>
                  </li>
                ))}
              </ul>
            )}
            {lesson.competencyRequired?.trim() && (
              <p class="lesson-prereq-note">{lesson.competencyRequired}</p>
            )}
          </section>
        )}
      </div>

      <aside class="lesson-sidebar" aria-label="Lesson details">
        <div class="page-section">
          <h2 class="section-heading">Details</h2>

          {lesson.author?.trim() && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Author</span>
              <span class="lesson-detail-value">{lesson.author}</span>
            </div>
          )}

          {lesson.audience?.trim() && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Suitable for</span>
              <span class="lesson-detail-value">{lesson.audience}</span>
            </div>
          )}

          {licenseShort && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">License</span>
              <span class="lesson-detail-value">
                {lesson.license?.startsWith("http") ? (
                  <a
                    href={lesson.license}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {licenseShort}
                  </a>
                ) : (
                  licenseShort
                )}
              </span>
            </div>
          )}

          {lesson.inLanguage && lesson.inLanguage.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Language</span>
              <span class="lesson-detail-value">
                {lesson.inLanguage.join(", ")}
              </span>
            </div>
          )}

          {ossRoles.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">OSS role</span>
              <span class="lesson-detail-value">{ossRoles.join(", ")}</span>
            </div>
          )}

          {keywordList.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Topics</span>
              <div class="lesson-tags">
                {keywordList.map((tag) => (
                  <span class="lesson-tag">{tag}</span>
                ))}
              </div>
            </div>
          )}
        </div>

        {lesson.repoUrl?.trim() && (
          <div class="page-section">
            <h2 class="section-heading">Source</h2>
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Repository</span>
              <span class="lesson-detail-value">
                <a
                  href={lesson.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  GitHub ↗
                </a>
              </span>
            </div>
            {repoLastUpdated && (
              <div class="lesson-detail-row">
                <span class="lesson-detail-label">Last updated</span>
                <span class="lesson-detail-value">
                  {formatMonth(repoLastUpdated)}
                </span>
              </div>
            )}
          </div>
        )}

        <div class="page-section" aria-labelledby="cite-heading">
          <h2 class="section-heading" id="cite-heading">Cite this lesson</h2>
          {cffCitation && (
            <p class="lesson-cite-note">
              Metadata from <code>CITATION.cff</code>.
            </p>
          )}

          <div class="lesson-cite-block">
            <div class="lesson-cite-header">
              <span class="lesson-cite-label">APA</span>
              <button class="lesson-cite-copy" data-copy={apaCitation} aria-label="Copy APA citation">
                Copy
              </button>
            </div>
            <p class="lesson-cite-text">{apaCitation}</p>
          </div>

          <div class="lesson-cite-block">
            <div class="lesson-cite-header">
              <span class="lesson-cite-label">BibTeX</span>
              <button class="lesson-cite-copy" data-copy={bibtexCitation} aria-label="Copy BibTeX citation">
                Copy
              </button>
            </div>
            <pre class="lesson-cite-pre"><code>{bibtexCitation}</code></pre>
          </div>
        </div>
      </aside>

    </div>

    <section class="page-section lesson-related" aria-labelledby="related-heading">
      <h2 class="section-heading" id="related-heading">Related lessons</h2>
      {relatedLessons.length === 0 ? (
        <p class="section-copy">No related lessons found yet.</p>
      ) : (
        <div class="related-grid">
          {relatedLessons.map((related) => (
            <a
              class="related-card"
              href={`${import.meta.env.BASE_URL}lessons/${related.slug}`}
            >
              <h3 class="related-title">{related.name}</h3>
              <p class="related-meta">
                {related.educationalLevel}
                {related.subTopic?.trim() ? ` • ${related.subTopic.trim()}` : ""}
              </p>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
<script>
  document.querySelectorAll<HTMLButtonElement>('.lesson-cite-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy;
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = original; }, 2000);
      });
    });
  });
</script>
</BaseLayout>

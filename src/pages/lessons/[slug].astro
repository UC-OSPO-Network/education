---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LessonJsonLd from "../../components/LessonJsonLd.astro";
import Citation from "../../components/Citation.astro";
import { getLessons, getRelatedLessons, type Lesson, formatDuration } from "../../lib/lessons";
import { lookupProvider } from "../../lib/providers";
import { normalizeCitation } from "../../lib/citation";
import { getCollection } from "astro:content";
import githubHealthRaw from "../../data/github-health.json";
import type { HealthSnapshot } from "../../lib/githubHealth";

const healthData = githubHealthRaw as unknown as HealthSnapshot;

type Props = {
  lesson: Lesson;
  relatedLessons: Lesson[];
  prereqLessons: { slug: string; name: string }[];
  pathwayName: string;
  pathwayId: string;
};

export async function getStaticPaths() {
  const [lessons, pathways] = await Promise.all([getLessons(), getCollection("pathways")]);
  const pathwayMap = Object.fromEntries(pathways.map((p) => [p.id, p.data.name]));
  const slugToName = Object.fromEntries(lessons.map((l) => [l.slug, l.name]));

  const candidates = lessons.filter(
    (lesson) => typeof lesson.slug === "string" && lesson.slug.trim().length > 0,
  );

  return candidates.map((lesson) => {
    const pathwayId = lesson.pathways[0] ?? "";
    const pathwayName = pathwayMap[pathwayId] ?? "";
    const relatedLessons = getRelatedLessons(lesson, lessons);
    const prereqLessons = lesson.prerequisites
      .filter((p) => p.type === "lesson" && slugToName[p.value])
      .map((p) => ({ slug: p.value, name: slugToName[p.value] }));

    return {
      params: { slug: lesson.slug },
      props: { lesson, relatedLessons, prereqLessons, pathwayName, pathwayId } satisfies Props,
    };
  });
}

const { lesson, relatedLessons, prereqLessons, pathwayName, pathwayId } = Astro.props as Props;

const pathwayHref = pathwayId ? `${import.meta.env.BASE_URL}pathways/${pathwayId}` : "";
const summary = lesson.description?.trim() || lesson.abstract?.trim() || "";
const externalHref = lesson.url?.trim() ?? "";

const repoHealth = healthData.lessons[lesson.slug] ?? null;
const repoLastUpdated = repoHealth?.pushedAt ?? null;

const provider = lesson.provider ? lookupProvider(lesson.provider) : null;

const normalizedCitation = normalizeCitation({
  lessonName: lesson.name,
  lessonAuthor: lesson.author,
  lessonUrl: lesson.url,
  repoUrl: lesson.repoUrl,
  cffCitation: repoHealth?.citation ?? null,
  provider: provider,
});

// URL prerequisites to display alongside internal lesson links
const prereqUrls = lesson.prerequisites.filter(
  (p): p is { type: "url"; value: string; label?: string } => p.type === "url",
);

const outcomeLines = (lesson.learningObjectives ?? "")
  .split("\n")
  .map((l) => l.trim())
  .filter((l) => l.startsWith("- ") || l.startsWith("* "))
  .map((l) => l.replace(/^[-*]\s+/, ""));

const duration = formatDuration(lesson.timeRequired);

function shortLicense(url: string | undefined): string {
  if (!url) return "";
  const m = url.match(/licenses\/([^/]+)\/([^/]+)/);
  if (m) return `CC ${m[1].toUpperCase()} ${m[2]}`;
  const m2 = url.match(/licenses\/([^/]+)/);
  if (m2) return `CC ${m2[1].toUpperCase()}`;
  return url;
}

function formatMonth(dateStr: string | null): string {
  if (!dateStr) return "";
  const parts = dateStr.split("-");
  const year = parts[0];
  const month = parseInt(parts[1], 10);
  const names = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${names[month - 1]} ${year}`;
}

function filterHref(param: string, value: string): string {
  const params = new URLSearchParams();
  params.set(param, value);
  return `${import.meta.env.BASE_URL}lessons/?${params.toString()}`;
}

function splitList(value: string): string[] {
  return value.split(",").map((item) => item.trim()).filter(Boolean);
}

const audienceLinks = splitList(lesson.audience);
const licenseShort = shortLicense(lesson.license);
const hasPrereqs =
  prereqLessons.length > 0 ||
  prereqUrls.length > 0 ||
  !!lesson.competencyRequired?.trim();
---

<BaseLayout title={lesson.name} description={summary}>
  {/* Pagefind filter metadata — visually hidden, indexed for faceted search */}
  <div class="sr-only" aria-hidden="true">
    {lesson.educationalLevel && <span data-pagefind-filter="level">{lesson.educationalLevel}</span>}
    {lesson.domain && <span data-pagefind-filter="domain">{lesson.domain}</span>}
    {lesson.roles.map((role) => <span data-pagefind-filter="role">{role}</span>)}
    {lesson.pathways.map((p) => <span data-pagefind-filter="pathway">{p}</span>)}
    {lesson.provider && <span data-pagefind-filter="provider">{lesson.provider}</span>}
    {lesson.learningResourceType && <span data-pagefind-filter="type">{lesson.learningResourceType}</span>}
    {audienceLinks.map((audience) => <span data-pagefind-filter="audience">{audience}</span>)}
    {lesson.keywords.map((topic) => <span data-pagefind-filter="topic">{topic}</span>)}
    <span data-pagefind-meta="type">lesson</span>
  </div>
  <Fragment slot="head">
    <LessonJsonLd lesson={lesson} canonicalUrl={Astro.url.href} />
  </Fragment>

  <section class="page-intro">
    <div class="content-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href={import.meta.env.BASE_URL}>Home</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li><a href={`${import.meta.env.BASE_URL}lessons`}>Lessons</a></li>
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li aria-current="page">{lesson.name}</li>
        </ol>
      </nav>

      <div class="lesson-badges">
        {pathwayName && (
          <span class="lesson-badge lesson-badge--pathway">
            {pathwayName}
          </span>
        )}
        {lesson.educationalLevel && (
          <span class="lesson-badge lesson-badge--level">
            {lesson.educationalLevel}
          </span>
        )}
        {duration && (
          <span class="lesson-badge lesson-badge--time">{duration}</span>
        )}
      </div>

      <h1 class="page-intro__title">{lesson.name}</h1>
      {summary && <p class="page-intro__summary">{summary}</p>}

      <div class="page-intro__actions">
        <a
          class="button-primary"
          href={externalHref || "#"}
          target={externalHref ? "_blank" : undefined}
          rel={externalHref ? "noopener noreferrer" : undefined}
          aria-disabled={externalHref ? "false" : "true"}
        >
          View Lesson ↗
        </a>
        {pathwayHref && (
          <a class="button-secondary" href={pathwayHref}>Browse Pathway</a>
        )}
      </div>
    </div>
  </section>

  <div class="content-container">
    <div class="lesson-detail">

      <div class="lesson-body">
        {outcomeLines.length > 0 && (
          <section class="page-section" aria-labelledby="outcomes-heading">
            <h2 class="section-heading" id="outcomes-heading">Learning outcomes</h2>
            <ul class="lesson-outcomes">
              {outcomeLines.map((line) => <li>{line}</li>)}
            </ul>
          </section>
        )}

        {hasPrereqs && (
          <section class="page-section" aria-labelledby="prereqs-heading">
            <h2 class="section-heading" id="prereqs-heading">Prerequisites</h2>
            {prereqLessons.length > 0 && (
              <ul class="lesson-prereq-list">
                {prereqLessons.map(({ slug, name }) => (
                  <li>
                    <a href={`${import.meta.env.BASE_URL}lessons/${slug}`}>
                      {name}
                    </a>
                  </li>
                ))}
              </ul>
            )}
            {prereqUrls.length > 0 && (
              <ul class="lesson-prereq-list">
                {prereqUrls.map((p) => (
                  <li>
                    <a href={p.value} target="_blank" rel="noopener noreferrer">
                      {p.label ?? p.value}
                    </a>
                  </li>
                ))}
              </ul>
            )}
            {lesson.competencyRequired?.trim() && (
              <p class="lesson-prereq-note">{lesson.competencyRequired}</p>
            )}
          </section>
        )}
      </div>

      <aside class="lesson-sidebar" aria-label="Lesson details" data-pagefind-ignore>
        <div class="page-section">
          <h2 class="section-heading">Details</h2>

          {provider && (
            <div class="lesson-detail-row lesson-detail-row--provider">
              <span class="lesson-detail-label">Provider</span>
              <div class="lesson-detail-value">
                <a href={provider.url} target="_blank" rel="noopener noreferrer" class="lesson-provider-link">
                  {provider.name} ↗
                </a>
                <p class="lesson-provider-desc">{provider.shortDescription}</p>
              </div>
            </div>
          )}

          {lesson.author?.trim() && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Author</span>
              <span class="lesson-detail-value">{lesson.author}</span>
            </div>
          )}

          {audienceLinks.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Suitable for</span>
              <span class="lesson-detail-value lesson-filter-links">
                {audienceLinks.map((audience) => (
                  <a href={filterHref("audience", audience)}>{audience}</a>
                ))}
              </span>
            </div>
          )}

          {licenseShort && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">License</span>
              <span class="lesson-detail-value">
                {lesson.license?.startsWith("http") ? (
                  <a
                    href={lesson.license}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {licenseShort}
                  </a>
                ) : (
                  licenseShort
                )}
              </span>
            </div>
          )}

          {lesson.inLanguage && lesson.inLanguage.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Language</span>
              <span class="lesson-detail-value">
                {lesson.inLanguage.join(", ")}
              </span>
            </div>
          )}

          {lesson.roles.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">OSS role</span>
              <span class="lesson-detail-value lesson-filter-links">
                {lesson.roles.map((role) => (
                  <a href={filterHref("role", role)}>{role}</a>
                ))}
              </span>
            </div>
          )}

          {lesson.learningResourceType?.trim() && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Learning type</span>
              <span class="lesson-detail-value lesson-filter-links">
                <a href={filterHref("type", lesson.learningResourceType)}>{lesson.learningResourceType}</a>
              </span>
            </div>
          )}

          {lesson.keywords.length > 0 && (
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Topics</span>
              <div class="lesson-tags">
                {lesson.keywords.map((tag) => (
                  <a class="lesson-tag" href={filterHref("topic", tag)}>{tag}</a>
                ))}
              </div>
            </div>
          )}
        </div>

        {lesson.repoUrl?.trim() && (
          <div class="page-section">
            <h2 class="section-heading">Source</h2>
            <div class="lesson-detail-row">
              <span class="lesson-detail-label">Repository</span>
              <span class="lesson-detail-value">
                <a
                  href={lesson.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  GitHub ↗
                </a>
              </span>
            </div>
            {repoLastUpdated && (
              <div class="lesson-detail-row">
                <span class="lesson-detail-label">Last updated</span>
                <span class="lesson-detail-value">
                  {formatMonth(repoLastUpdated)}
                </span>
              </div>
            )}
          </div>
        )}

        <Citation lessonSlug={lesson.slug} citation={normalizedCitation} />
      </aside>

    </div>

    <section class="page-section lesson-related" aria-labelledby="related-heading">
      <h2 class="section-heading" id="related-heading">Related lessons</h2>
      {relatedLessons.length === 0 ? (
        <p class="section-copy">No related lessons found yet.</p>
      ) : (
        <div class="related-grid">
          {relatedLessons.map((related) => (
            <a
              class="related-card"
              href={`${import.meta.env.BASE_URL}lessons/${related.slug}`}
            >
              <h3 class="related-title">{related.name}</h3>
              <p class="related-meta">
                {related.educationalLevel}
                {related.subTopic?.trim() ? ` • ${related.subTopic.trim()}` : ""}
              </p>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

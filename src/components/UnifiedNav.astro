---
import { isCurrentItem, isCurrentLink, siteChrome, withBasePath } from "../lib/siteChrome";

const basePath = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-brand" href={siteChrome.brand.homeHref}>
      <img
        class="site-brand__mark"
        src={`${import.meta.env.BASE_URL}uc-ospo-logo.svg`}
        alt="UC OSPO logo"
      />
      <span class="site-brand__copy">
        <span class="site-brand__title">{siteChrome.brand.label}</span>
        <span class="site-brand__subtitle">{siteChrome.brand.subtitle}</span>
      </span>
    </a>

    <button
      type="button"
      class="site-menu-toggle"
      id="site-menu-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      Menu
    </button>

    <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
      <ul class="site-nav__list">
        {siteChrome.nav.map((item, index) => {
          const current = isCurrentItem(basePath, Astro.url.pathname, item);
          const itemClasses = ["site-nav__item", current ? "is-current" : ""].filter(Boolean).join(" ");
          const menuId = `site-nav-menu-${index}`;
          const itemHref = item.external ? item.href : withBasePath(import.meta.env.BASE_URL, item.href);

          return (
            <li class={itemClasses}>
              {item.children?.length ? (
                <>
                  <button
                    type="button"
                    class="site-nav__trigger"
                    data-nav-toggle
                    aria-expanded="false"
                    aria-controls={menuId}
                  >
                    <span>{item.label}</span>
                    <span class="site-nav__caret" aria-hidden="true">▾</span>
                  </button>
                  <div class="site-nav__menu" id={menuId}>
                    {item.children.map((child) => {
                      const childCurrent = isCurrentLink(basePath, Astro.url.pathname, child.href);
                      return (
                        <a
                          class={`site-nav__menu-link${childCurrent ? " is-current" : ""}`}
                          href={child.external ? child.href : withBasePath(import.meta.env.BASE_URL, child.href)}
                          target={child.external ? "_blank" : undefined}
                          rel={child.external ? "noopener noreferrer" : undefined}
                        >
                          {child.label}
                        </a>
                      );
                    })}
                  </div>
                </>
              ) : (
                <a
                  class="site-nav__link"
                  href={itemHref}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener noreferrer" : undefined}
                >
                  {item.label}
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById("site-nav");
  const menuToggle = document.getElementById("site-menu-toggle");
  const navItems = Array.from(document.querySelectorAll(".site-nav__item"));
  const toggles = Array.from(document.querySelectorAll("[data-nav-toggle]"));

  function closeMenus(exceptItem) {
    navItems.forEach((item) => {
      if (exceptItem && item === exceptItem) return;
      item.classList.remove("is-open");
      const toggle = item.querySelector("[data-nav-toggle]");
      if (toggle) toggle.setAttribute("aria-expanded", "false");
    });
  }

  if (menuToggle && nav) {
    menuToggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("is-open");
      menuToggle.setAttribute("aria-expanded", String(isOpen));
      if (!isOpen) closeMenus();
    });
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", (event) => {
      const item = event.currentTarget.closest(".site-nav__item");
      if (!item) return;

      const willOpen = !item.classList.contains("is-open");
      closeMenus(willOpen ? item : undefined);
      item.classList.toggle("is-open", willOpen);
      toggle.setAttribute("aria-expanded", String(willOpen));
    });
  });

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;
    if (nav?.contains(event.target) || menuToggle?.contains(event.target)) return;
    nav?.classList.remove("is-open");
    menuToggle?.setAttribute("aria-expanded", "false");
    closeMenus();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;
    nav?.classList.remove("is-open");
    menuToggle?.setAttribute("aria-expanded", "false");
    closeMenus();
    menuToggle?.focus();
  });
</script>

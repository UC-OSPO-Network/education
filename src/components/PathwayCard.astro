---
interface Props {
  pathway: {
    id: string;
    name: string;
    description: string;
    icon: string;
  };
  lessonCount?: number;
}

const { pathway, lessonCount = 0 } = Astro.props;
---

<style>
  .pathway-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: 1.5rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
    text-decoration: none;
    display: block;
    position: relative;
    overflow: hidden;
  }

  .pathway-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--uc-blue);
  }

  .pathway-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-strong);
    text-decoration: none;
  }

  .pathway-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .pathway-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .pathway-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .pathway-description {
    color: var(--text-secondary);
    font-size: 0.98rem;
    margin: 0;
    line-height: 1.5;
  }

  .pathway-count {
    display: inline-block;
    margin-top: 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
  }
</style>

<a href={`${import.meta.env.BASE_URL}pathways/${pathway.id}`} class="pathway-card">
  <div class="pathway-header">
    <span class="pathway-icon">{pathway.icon}</span>
    <h2 class="pathway-title">{pathway.name}</h2>
  </div>
  <p class="pathway-description">{pathway.description}</p>
  {lessonCount > 0 && (
    <span class="pathway-count">{lessonCount} {lessonCount === 1 ? "lesson" : "lessons"}</span>
  )}
</a>

---
import type { Lesson } from "../lib/lessons";
import { getCollection } from "astro:content";

interface Props {
  lesson: Lesson;
  canonicalUrl: string;
}

const { lesson, canonicalUrl } = Astro.props as Props;

const pathways = await getCollection("pathways");
const pathwayMap = Object.fromEntries(pathways.map((p) => [p.id, p.data.name]));

function nonEmpty(value: unknown): boolean {
  if (value === null || value === undefined) return false;
  if (typeof value === "string") return value.trim() !== "";
  if (Array.isArray(value)) return value.length > 0;
  return true;
}

const data: Record<string, unknown> = {
  "@context": ["https://schema.org", "https://bioschemas.org"],
  "@type": "TrainingMaterial",
};

if (nonEmpty(lesson.name)) data.name = lesson.name;
if (nonEmpty(lesson.abstract || lesson.description))
  data.description = (lesson.abstract || lesson.description).trim();
if (nonEmpty(canonicalUrl)) data.url = canonicalUrl;
if (nonEmpty(lesson.educationalLevel)) data.educationalLevel = lesson.educationalLevel;
if (nonEmpty(lesson.learningResourceType)) data.learningResourceType = lesson.learningResourceType;
if (nonEmpty(lesson.keywords)) data.keywords = lesson.keywords;
if (nonEmpty(lesson.timeRequired)) data.timeRequired = lesson.timeRequired;
if (nonEmpty(lesson.inLanguage)) data.inLanguage = lesson.inLanguage;
if (nonEmpty(lesson.license)) data.license = lesson.license;
if (nonEmpty(lesson.author)) data.author = { "@type": "Person", name: lesson.author };
if (nonEmpty(lesson.learningObjectives)) data.teaches = lesson.learningObjectives;

if (lesson.roles.length > 0) {
  data.audience = lesson.roles.map((role) => ({
    "@type": "Audience",
    audienceType: role,
  }));
}

if (lesson.pathways.length > 0) {
  data.isPartOf = lesson.pathways.map((id) => ({
    "@type": "Course",
    name: pathwayMap[id] ?? id,
  }));
}

const prereqLabels = lesson.prerequisites
  .filter((p) => p.type !== "text")
  .map((p) => p.label || p.value)
  .filter(Boolean);
if (prereqLabels.length > 0) data.competencyRequired = prereqLabels;
---

<script type="application/ld+json" set:html={JSON.stringify(data)} />
